{
  "ci": {
    "collect": {
      "staticDistDir": ".",
      "url": [
        "http://localhost/index.html",
        "http://localhost/directory.html",
        "http://localhost/docs/research.html",
        "http://localhost/docs/validation.html",
        "http://localhost/pages/hospital-homepage.html",
        "http://localhost/pages/hospital-specialty.html",
        "http://localhost/pages/hospital-find-a-doctor.html",
        "http://localhost/pages/hospital-provider.html",
        "http://localhost/pages/hospital-patient-visitor.html",
        "http://localhost/pages/hospital-measure.html",
        "http://localhost/pages/hospital-appointment.html",
        "http://localhost/pages/hospital-search.html",
        "http://localhost/pages/hospital-login.html",
        "http://localhost/pages/hospital-settings.html",
        "http://localhost/pages/hospital-portal.html",
        "http://localhost/pages/hospital-booking.html",
        "http://localhost/pages/hospital-medication.html",
        "http://localhost/pages/hospital-trial.html",
        "http://localhost/pages/university-homepage.html",
        "http://localhost/pages/university-program.html",
        "http://localhost/pages/university-faculty.html"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-byte-weight": ["warn", { "maxNumericValue": 250000 }],
        "uses-text-compression": "off",
        "uses-long-cache-ttl": "off",
        "is-on-https": "off",
        "redirects-http": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
